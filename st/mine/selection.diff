diff --git a/x.c b/x.c
index d73152b..e533b87 100644
--- a/x.c
+++ b/x.c
@@ -221,6 +221,11 @@ static XWindow xw;
 static XSelection xsel;
 static TermWindow win;
 
+/* Selection drag threshold */
+static int sel_pending = 0;
+static int sel_pending_x, sel_pending_y;
+static int sel_pending_snap;
+
 /* Font Ring Cache */
 enum {
 	FRC_NORMAL,
@@ -484,10 +489,6 @@ bpress(XEvent *e)
 		return;
 
 	if (btn == Button1) {
-		/*
-		 * If the user clicks below predefined timeouts specific
-		 * snapping behaviour is exposed.
-		 */
 		clock_gettime(CLOCK_MONOTONIC, &now);
 		if (TIMEDIFF(now, xsel.tclick2) <= tripleclicktimeout) {
 			snap = SNAP_LINE;
@@ -499,7 +500,10 @@ bpress(XEvent *e)
 		xsel.tclick2 = xsel.tclick1;
 		xsel.tclick1 = now;
 
-		selstart(evcol(e), evrow(e), snap);
+		sel_pending = 1;
+		sel_pending_x = e->xbutton.x;
+		sel_pending_y = e->xbutton.y;
+		sel_pending_snap = snap;
 	}
 }
 
@@ -709,8 +713,10 @@ brelease(XEvent *e)
 
 	if (mouseaction(e, 1))
 		return;
-	if (btn == Button1)
+	if (btn == Button1) {
+		sel_pending = 0;
 		mousesel(e, 1);
+	}
 }
 
 void
@@ -721,6 +727,18 @@ bmotion(XEvent *e)
 		return;
 	}
 
+	if (sel_pending) {
+		if (abs(e->xbutton.x - sel_pending_x) <= 5 &&
+		    abs(e->xbutton.y - sel_pending_y) <= 5)
+			return;
+		selstart(
+			(LIMIT(sel_pending_x - borderpx, 0, win.tw-1)) / win.cw,
+			(LIMIT(sel_pending_y - borderpx, 0, win.th-1)) / win.ch,
+			sel_pending_snap
+		);
+		sel_pending = 0;
+	}
+
 	mousesel(e, 0);
 }
 
