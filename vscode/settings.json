// Place your settings in this file to overwrite default and user settings.
{
    "editor.fontFamily": "Consolas",
    "editor.fontSize": 14,
    "editor.letterSpacing": 0,
    "explorer.openEditors.visible": 1,
    "workbench.editor.showTabs": "multiple",
    "workbench.sideBar.location": "right",
    "search.exclude":
    {
        "**/wwwroot": true,
        "**/typings": true,
        "**/out": true,
        "**/cdn": true
    },
    "workbench.editor.enablePreview": true,
    "editor.wordWrap": "off",
    "explorer.autoReveal": true,
    "files.exclude":
    {
        "**/node_modules": true,
        "**/bower_components": true,
        "**/bin": true,
        "**/obj": true
    },
    "editor.minimap.enabled": false,
    "git.enableSmartCommit": true,
    "telemetry.telemetryLevel": "off",
    "workbench.colorTheme": "Light+",
    "extensions.autoUpdate": false,
    "extensions.ignoreRecommendations": true,
    "workbench.iconTheme": "simple-icons",
    "editor.dragAndDrop": false,
    "window.zoomLevel": 0,
    "workbench.colorCustomizations": {
        "gitDecoration.modifiedResourceForeground": "#FF8C00",
        "gitDecoration.untrackedResourceForeground": "#32CD32"
    },
    "workbench.editor.decorations.colors": false,
    "workbench.editor.decorations.badges": false,
    "explorer.decorations.badges": false,
    "problems.decorations.enabled": false,
    "breadcrumbs.enabled": false,
    "explorer.confirmDelete": false,
    "window.titleBarStyle": "custom",
    "window.restoreWindows": "none",
    "workbench.settings.editor": "json",
    "debug.console.fontFamily": "Consolas",
    "terminal.external.linuxExec": "termite2",
    "terminal.external.windowsExec": "C:\\Program Files\\Git\\bin\\bash.exe",
    "terminal.explorerKind": "external",
    "update.mode": "none",
    "files.watcherExclude": {
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/node_modules/*/**": true,
        "**/lib_bower/*/**": true
    },
    "js/ts.updateImportsOnFileMove.enabled": "never",
    "explorer.compactFolders": false,
    "files.associations": {
        "autostart": "shellscript",
        "minirc.conf": "shellscript",
        "inittab": "shellscript",
        "minirc.local": "shellscript",
        "minirc.local.shutdown": "shellscript",
        "rc": "shellscript",
        "aliases": "shellscript"
    },
    "security.workspace.trust.enabled": false,
    "files.hotExit": "off",
    "files.enableTrash": false,
    "github.gitAuthentication": false,
    "editor.semanticHighlighting.enabled": true,
    "git.autofetch": false,
    "terminal.integrated.persistentSessionReviveProcess": "never",
    "terminal.integrated.tabs.enabled": false,
    "diffEditor.ignoreTrimWhitespace": false,
    "shellcheck.customArgs": ["-x"],
    "editor.scrollbar.verticalScrollbarSize": 25,
    "git.showActionButton": {
        "commit": false,
        "publish": false,
        "sync": false
    },
    "editor.roundedSelection": false,
    "diffEditor.experimental.showEmptyDecorations": false,
    "window.commandCenter": false,
    "editor.useTabStops": false,
    "editor.trimAutoWhitespace": false,
    "editor.folding": true,
    "editor.stickyScroll.enabled": false,
    "diffEditor.wordWrap": "off",
    "[json]": {
        "editor.tabSize": 2
    },
    "[javascript]": {
        "editor.tabSize": 2
    },
    "git.discardUntrackedChangesToTrash": false,
    "workbench.tree.enableStickyScroll": false,
    "workbench.browser.showInTitleBar": false,
    "workbench.layoutControl.enabled": false,
    "workbench.editor.useModal": "off",
    "chat.disableAIFeatures": true,
    "simpleIcons.hideArrows": false,
    "js/ts.referencesCodeLens.enabled": true,
    "js/ts.referencesCodeLens.showOnAllFunctions": true,
    "js/ts.implementationsCodeLens.enabled": true,
    "js/ts.implementationsCodeLens.showOnAllClassMethods": true,
    "js/ts.implementationsCodeLens.showOnInterfaceMethods": true,
    "keyboard.dispatch": "keyCode"
}
